# Set backend environment variables.
#
# Convex Cloud:
# - use CONVEX_DEPLOYMENT + CONVEX_URL + CONVEX_SITE_URL
# - `convex dev` writes these into .env.local during setup
#
# Self-hosted Convex:
# - use CONVEX_SELF_HOSTED_URL + CONVEX_SELF_HOSTED_ADMIN_KEY
# - keep a separate .env.production.local for production deploys
# - deploy with `convex deploy --env-file .env.production.local`
# - runtime knobs like DATABASE_UDF_USER_TIMEOUT_SECONDS belong on the
#   self-hosted Convex server process/container, not in Convex function env

# Add DATABASE_UDF_USER_TIMEOUT_SECONDS value in railway or your hosting provider for better handling of long-running requests. This is not needed for Convex Cloud.

# Auth
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=

# Frontend and native redirect targets
SITE_URL=http://localhost:3004
NATIVE_APP_URL=feelchat://

# Convex site/actions host used by Better Auth and HTTP actions.
# For Convex Cloud this is usually the `.convex.site` URL.
# For self-hosted this is your actions/site host, for example https://actions.example.com.
CONVEX_SITE_URL=

# Client-side auth proxies point at the site/actions host.
EXPO_PUBLIC_CONVEX_SITE_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Convex Cloud deployment used by `convex dev`
CONVEX_DEPLOYMENT= # team: your-team, project: your-project
CONVEX_URL=

# Self-hosted Convex deploy target
CONVEX_SELF_HOSTED_URL=
CONVEX_SELF_HOSTED_ADMIN_KEY=

# Polar cloud env
# npx convex env set POLAR_ORGANIZATION_TOKEN your_token
# npx convex env set POLAR_WEBHOOK_SECRET your_webhook_secret
# npx convex env set POLAR_PRODUCT_PRO_MONTHLY product_id_from_polar
# npx convex env set POLAR_PRODUCT_PRO_YEARLY product_id_from_polar

# Polar
POLAR_ORGANIZATION_TOKEN=
POLAR_WEBHOOK_SECRET=

# Agent provider config
# "gateway" routes agent text generation through Vercel AI Gateway
# "openrouter" routes agent text generation through OpenRouter
AI_AGENT_PROVIDER=gateway
# Provider-specific model ID used for agent replies
AI_AGENT_MODEL=google/gemini-3-flash
# Optional: when set and AI_GATEWAY_API_KEY is available, semantic vector search
# stays enabled for agent history retrieval. Leave empty to disable embeddings.
AI_AGENT_EMBEDDING_MODEL=openai/text-embedding-3-small

# Agent API Keys
AI_GATEWAY_API_KEY=
# Optional: OpenAI-compatible gateway base URL
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1/ai
OPENROUTER_API_KEY=
# Optional: model used for profile blueprint generation
PROFILE_GENERATION_MODEL=google/gemini-3-flash
# Optional: comma-separated fallback models (tried in order if primary fails)
PROFILE_GENERATION_FALLBACK_MODELS=google/gemini-2.5-flash,openai/gpt-4.1-mini,anthropic/claude-3-5-haiku-latest

#Cloudflare R2
R2_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# Replicate API Token
REPLICATE_API_TOKEN=
